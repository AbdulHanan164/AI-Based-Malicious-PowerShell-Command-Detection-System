{
  "experimentalServices": {
    "frontend": {
      "src": "frontend",
      "framework": "vite",
      "buildCommand": "npm run build",
      "outputDirectory": "dist",
      "installCommand": "npm install"
    },
    "backend": {
      "src": "backend",
      "framework": "fastapi",
      "installCommand": "pip install -r requirements.txt",
      "startCommand": "uvicorn main:app --host 0.0.0.0 --port $PORT"
    }
  }
}
